# Workspace-level ignore rules for local/generated artifacts only.
# Keep source code, docs under docs/, and project assets trackable by default.

# OS junk
.DS_Store
Thumbs.db
desktop.ini
*.lnk

# Generic temp / backup files
*~
*.swp
*.swo
*.tmp
*.bak
*.old
*.orig

# Editors / IDEs
.vscode/
.idea/
.vs/
*.code-workspace
*.iml

# Agent / tooling caches
.serena/
**/.serena/
.codex/
**/.codex/
.claude/
**/.claude/
.cache/
**/.cache/

# Planning / session scratch files
/.merge-backup/
/findings.md
/progress.md
/tmp_*.ps1
/tmp_*.txt

# Build systems and generated outputs
**/build/
**/build_*/
**/build_tmp*/
**/build_cmake_check/
**/.hard-gate-build/
**/cmake-build-*/
**/CMakeFiles/
**/CMakeCache.txt
**/cmake_install.cmake
**/install_manifest.txt
**/CMakeUserPresets.json
**/.ninja_deps
**/.ninja_log
**/compile_commands.json

# Binary / firmware / debug artifacts
*.o
*.obj
*.a
*.lib
*.so
*.dll
*.dylib
*.exe
*.elf
*.hex
*.bin
*.map
*.d
*.dep
*.lst
*.su
*.pdb
*.ilk
*.idb
*.ipch
*.tlog
*.VC.db
*.VC.VC.opendb

# Python artifacts
**/__pycache__/
**/*.pyc
**/.pytest_cache/
.venv/
venv/

# Runtime logs / recordings
**/logs/
**/records/
**/records_*/
**/records-*/
**/MvSdkLog/

# Nested git metadata
**/.git/
**/.git
**/.git.bak*/
**/.git_backup*/

# Local helper instructions that are not part of the repo
/CLAUDE.md
**/CLAUDE.md

# Local reference material and extracted third-party workspaces
/RM2024-PowerModule-main/
/robowalker2024bottominfantry-main/
/Sliding-master/
/Sliding-master.zip
/rmpp-master/
/Gimbal/build_fc_removed/

# Root-level local manuals / notes kept outside version control
/*.pdf
/*.zip
/Yaw*.md
