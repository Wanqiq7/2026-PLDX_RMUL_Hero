{
  "contract_version": "phase3-golden-v1",
  "module": "power_controller",
  "focus": "PowerRLSUpdate",
  "harness": "tests/harnesses/power_controller_sample_harness.c",
  "samples": [
    {
      "sample_id": "rls-low-power-no-update-01",
      "purpose": "冻结低功率噪声输入下 RLS 不更新的行为。",
      "source": { "kind": "synthetic-boundary", "detail": "threshold guard sample" },
      "input": {
        "feedback_power_w": 4.0,
        "motor_speeds": [10.0, 10.0, 10.0, 10.0],
        "motor_torques": [1.0, 1.0, 1.0, 1.0],
        "referee_online": 1,
        "cap_online": 0,
        "run_task_iterations": 1
      },
      "expected_state": {
        "k1_after": 0.22,
        "k2_after": 1.2,
        "rls_updated": false
      },
      "tolerance": {
        "k1_after": 0.000001,
        "k2_after": 0.000001
      },
      "notes": "验证 |feedback_power_w| < 5W 时直接 return。"
    },
    {
      "sample_id": "rls-positive-loss-update-01",
