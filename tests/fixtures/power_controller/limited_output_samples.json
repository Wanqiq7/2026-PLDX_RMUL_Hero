{
  "contract_version": "phase3-golden-v1",
  "module": "power_controller",
  "focus": "PowerGetLimitedOutput",
  "harness": "tests/harnesses/power_controller_sample_harness.c",
  "samples": [
    {
      "sample_id": "limit-passthrough-01",
      "purpose": "冻结 sum_positive_power <= max_power 时的直通行为。",
      "source": { "kind": "baseline-current-implementation", "detail": "helper mirror baseline" },
      "input": {
        "max_power_w": 200.0,
        "referee_online": 1,
        "cap_online": 0,
        "run_task_iterations": 1,
        "feedback_motor_speeds": [18.0, 17.0, 16.0, 15.0],
        "feedback_motor_torques": [2.0, 1.8, 1.6, 1.4],
        "motor_objs": [
          { "pid_output": 2000.0, "current_av": 18.0, "target_av": 20.0 },
          { "pid_output": 1800.0, "current_av": 17.0, "target_av": 19.0 },
          { "pid_output": 1600.0, "current_av": 16.0, "target_av": 18.0 },
          { "pid_output": 1400.0, "current_av": 15.0, "target_av": 17.0 }
        ]
      },
      "expected_output": {
        "limited_output": [2000.0, 1800.0, 1600.0, 1400.0],
        "cmd_power_sum_w": 146.932,
        "effective_max_power_w": 200.0,
        "distribution_mode": "passthrough"
      },
      "tolerance": {
        "limited_output": 0.000001,
        "cmd_power_sum_w": 0.000001,
        "effective_max_power_w": 0.000001
      },
      "notes": "覆盖快路径。"
    },
    {
      "sample_id": "limit-mixed-distribution-01",
      "purpose": "冻结阈值中间区间的 mixed 分配行为。",
