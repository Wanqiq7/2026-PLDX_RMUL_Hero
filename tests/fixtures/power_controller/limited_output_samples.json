      },
      "expected_output": {
        "limited_output": [334.535173, 4800.0, 393.298846, 427.399728],
        "cmd_power_sum_w": 352.149,
        "effective_max_power_w": 50.0,
        "distribution_mode": "error"
      },
      "tolerance": {
        "limited_output": 0.000001,
        "cmd_power_sum_w": 0.000001,
        "effective_max_power_w": 0.000001
      },
      "notes": "这是需要在 Phase 4 前明确冻结的历史语义，不在本轮修复。"
    },
    {
      "sample_id": "limit-near-zero-and-discriminant-01",
      "purpose": "冻结近零力矩与低分配功率边界下的输出缩放行为。",
