      },
      "tolerance": {
        "limited_output": 0.000001,
        "cmd_power_sum_w": 0.000001,
        "effective_max_power_w": 0.000001
      },
      "notes": "覆盖带负功率支路的样本。"
    },
    {
      "sample_id": "limit-disconnect-historical-behavior-01",
      "purpose": "冻结断连电机在限功率路径中仍会被后续零功率分支覆盖回 pid_output 的历史行为。",
      "source": { "kind": "baseline-current-implementation", "detail": "helper mirror baseline" },
      "input": {
        "max_power_w": 50.0,
        "referee_online": 1,
        "cap_online": 0,
        "run_task_iterations": 1,
        "motor_online": [1, 0, 1, 1],
        "motor_disconnect_cycles": [0, 1000, 0, 0],
        "feedback_motor_speeds": [20.0, 19.0, 18.0, 17.0],
        "feedback_motor_torques": [5.0, 4.8, 4.6, 4.4],
        "motor_objs": [
          { "pid_output": 5000.0, "current_av": 20.0, "target_av": 26.0 },
          { "pid_output": 4800.0, "current_av": 19.0, "target_av": 25.0 },
          { "pid_output": 4600.0, "current_av": 18.0, "target_av": 24.0 },
          { "pid_output": 4400.0, "current_av": 17.0, "target_av": 23.0 }
