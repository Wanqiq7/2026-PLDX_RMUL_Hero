        "motor_objs": [
          { "pid_output": 6000.0, "current_av": 25.0, "target_av": 29.0 },
          { "pid_output": 5800.0, "current_av": 24.0, "target_av": 28.5 },
          { "pid_output": 5600.0, "current_av": 23.0, "target_av": 27.0 },
          { "pid_output": 5400.0, "current_av": 22.0, "target_av": 26.5 }
